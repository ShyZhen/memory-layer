{
  "name": "@shyzhen/memory-layer",
  "version": "0.9.0",
  "description": "专为企业级多用户 OpenClaw 智能体打造的多通道分层记忆插件,记忆数据隔离,重置会话不再丢失上下文。",
  "main": "index.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ShyZhen/memory-layer.git"
  },
  "homepage": "https://github.com/ShyZhen/memory-layer",
  "bugs": {
    "url": "https://github.com/ShyZhen/memory-layer/issues"
  },
  "scripts": {
    "build": "echo 'No build needed - jiti loads TS at runtime'",
    "type-check": "echo 'Type check skipped'",
    "test": "node --test tests/*.test.mjs"
  },
  "keywords": [
    "openclaw",
    "plugin",
    "memory",
    "layered-memory",
    "multi-user",
    "session-isolation",
    "dingtalk",
    "telegram",
    "钉钉",
    "记忆分层"
  ],
  "files": [
    "ARCHITECTURE.md",
    "README-en.md",
    "README.md",
    "core.mjs",
    "index.ts",
    "openclaw.plugin.json"
  ],
  "license": "MIT",
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24",
      "minGatewayVersion": "2026.3.24"
    },
    "build": {
      "openclawVersion": "2026.3.24",
      "pluginSdkVersion": "2026.3.24"
    },
    "installDependencies": false
  }
}
